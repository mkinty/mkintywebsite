# ------------------------------
# Image de base
# ------------------------------
FROM python:3.12-slim 

# ------------------------------
# Configuration de l'environnement
# ------------------------------
# Empêche Python de bufferiser les logs, pratique pour Docker (logs s'affichent en temps réel)
ENV PYTHONUNBUFFERED=1  

# Dossier de travail dans le container
WORKDIR /app 

# ------------------------------
# Installer les dépendances système nécessaires
# ------------------------------
RUN apt-get update && apt-get install -y \
    build-essential \  
    libpq-dev \ 
    curl \ 
    && rm -rf /var/lib/apt/lists/*  

# ------------------------------
# Installer uv (gestionnaire moderne des dépendances Python avec pyproject.toml)
# ------------------------------
RUN pip install uv

# ------------------------------
# Installer les dépendances Python globalement (accessibles par tous les scripts)
# ------------------------------
RUN pip install \
    django \  
    djangorestframework \  
    psycopg[binary] \  
    python-dotenv \  
    celery \ 
    redis   

# ------------------------------
# Copier les fichiers de dépendances pour uv
# ------------------------------
COPY pyproject.toml uv.lock* ./  

# Synchroniser avec uv pour que toutes les dépendances soient bien prises en compte
RUN uv sync

# ------------------------------
# Copier le code source dans le container
# ------------------------------
COPY src/ src/ 

# ------------------------------
# Commande par défaut pour lancer le serveur Django en développement
# ------------------------------
CMD ["python", "src/manage.py", "runserver", "0.0.0.0:8000"]  
# - 0.0.0.0 permet d'exposer le serveur sur toutes les interfaces (Docker host)
# - port 8000 exposé pour accès depuis l'extérieur du container